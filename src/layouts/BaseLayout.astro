---
import '../styles/global.css';
import SEO from '../components/SEO.astro';

interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogImage?: string;
  type?: string;
  publishedTime?: string;
  keywords?: string;
  noindex?: boolean;
  additionalLD?: object[];
}

const {
  title,
  description,
  canonical = Astro.url.href,
  ogImage = '/og-image.png',
  type = 'website',
  publishedTime,
  keywords,
  noindex = false,
  additionalLD = [],
} = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Sundeep Dayalan",
  "url": "https://www.sundeepdayalan.in",
  "image": "https://www.sundeepdayalan.in/profile.png",
  "jobTitle": "Senior Software Engineer",
  "description": "Senior Software Engineer with 5+ years architecting fault-tolerant distributed systems, LLM orchestration pipelines, and real-time fintech platforms.",
  "worksFor": {
    "@type": "Organization",
    "name": "Radiantze Inc"
  },
  "alumniOf": [
    {
      "@type": "CollegeOrUniversity",
      "name": "University of Colorado Denver",
      "url": "https://www.ucdenver.edu"
    },
    {
      "@type": "CollegeOrUniversity",
      "name": "Panimalar Engineering College"
    }
  ],
  "knowsAbout": [
    "Distributed Systems",
    "LLM Infrastructure",
    "Real-Time Fintech",
    "Python",
    "Django",
    "Java",
    "Spring Boot",
    "React",
    "TypeScript",
    "Apache Kafka",
    "Cloud Architecture",
    "Agentic AI"
  ],
  "sameAs": [
    "https://www.linkedin.com/in/sundeep-dayalan",
    "https://github.com/sundeep-dayalan",
    "https://www.sundeepdayalan.in"
  ]
};
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="X-UA-Compatible" content="IE=edge" />

    <SEO
      title={title}
      description={description}
      canonical={canonical}
      image={ogImage}
      type={type}
      publishedTime={publishedTime}
      keywords={keywords}
      noindex={noindex}
    />

    <!-- Person schema — present on every page -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <!-- Per-page structured data (SoftwareApplication, BreadcrumbList, WebSite, etc.) -->
    {additionalLD.map((schema) => (
      <script type="application/ld+json" set:html={JSON.stringify(schema)} />
    ))}

    <!-- apps.sundeepdayalan.in root → hub redirect (Netlify host-conditions unreliable) -->
    <script is:inline>
      if (location.hostname === 'apps.sundeepdayalan.in' && location.pathname === '/') {
        location.replace('/apps');
      }
    </script>
  </head>
  <body>
    <!-- Minimal Retro Theme applied -->

    <slot />

    <!-- ── LIGHTBOX ── -->
    <div id="lb-overlay" aria-modal="true" role="dialog" aria-label="Image viewer">
      <div id="lb-inner">
        <div class="lb-corner tl"></div>
        <div class="lb-corner tr"></div>
        <div class="lb-corner bl"></div>
        <div class="lb-corner br"></div>
        <div class="lb-hud">
          <span id="lb-label" class="lb-label">IMAGE</span>
          <button id="lb-close" aria-label="Close">✕ CLOSE</button>
        </div>
        <div id="lb-img-wrap">
          <img id="lb-img" src="" alt="" />
        </div>
        <div id="lb-caption"></div>
      </div>
    </div>

    <!-- Smooth scroll + intersection observer for animations -->
    <script>
      // Intersection Observer for fade-in animations
      const observerOptions = {
        threshold: 0.1,
        rootMargin: '0px 0px -50px 0px'
      };

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-visible');
            observer.unobserve(entry.target);
          }
        });
      }, observerOptions);

      document.querySelectorAll('.animate-on-scroll').forEach(el => {
        observer.observe(el);
      });

      // ── Lightbox ──
      const overlay  = document.getElementById('lb-overlay')!;
      const lbImg    = document.getElementById('lb-img') as HTMLImageElement;
      const lbCap    = document.getElementById('lb-caption')!;
      const lbLabel  = document.getElementById('lb-label')!;
      const lbClose  = document.getElementById('lb-close')!;

      const SELECTORS = [
        '.gallery-img-wrap img',
        '.module-img-wrap img',
        '.bay-img-wrap img',
        '.diagram-frame img',
        '.award-check-img img',
        '.award-photo-wrap img',
        '.jury-photo-wrap img',
        '.team-photo-wrap img',
        '.about-img-wrap img',
        '.phone-frame img',
        '.proto-photos img',
        '.realworld-photos img',
      ].join(', ');

      function openLightbox(img: HTMLImageElement) {
        lbImg.src = img.src;
        lbImg.alt = img.alt;
        lbCap.textContent = img.alt;
        // derive a label from the closest frame-label or alt
        const frameLabel = img.closest('[class]')?.parentElement?.querySelector('.frame-label');
        lbLabel.textContent = frameLabel?.textContent || 'IMAGE';
        overlay.classList.add('lb-open');
        document.body.style.overflow = 'hidden';
      }

      function closeLightbox() {
        overlay.classList.remove('lb-open');
        document.body.style.overflow = '';
        setTimeout(() => { lbImg.src = ''; }, 300);
      }

      document.querySelectorAll<HTMLImageElement>(SELECTORS).forEach(img => {
        img.style.cursor = 'zoom-in';
        img.addEventListener('click', (e) => {
          e.stopPropagation();
          openLightbox(img);
        });
      });

      lbClose.addEventListener('click', closeLightbox);
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) closeLightbox();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') closeLightbox();
      });
    </script>
  </body>
</html>
