---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const title = "Toolkit for WhatsApp | Sundeep Dayalan";
const description = "All-powerful tools for WhatsApp in one single app — Broadcaster, Sticker Maker, Photo Editor, Video Trimmer, and more. Built by Sundeep Dayalan.";

const topFeatures = [
  { title: "Broadcaster", subtitle: "bulk messaging", icon: "📡" },
  { title: "Insta", subtitle: "downloader", icon: "📥" },
  { title: "Memory", subtitle: "manager", icon: "💾" },
  { title: "Sticker", subtitle: "maker", icon: "🎨" },
  { title: "DP", subtitle: "editor", icon: "👤" },
  { title: "Video", subtitle: "trimmer", icon: "🎬" },
  { title: "Photo", subtitle: "editor", icon: "🖼️" },
];

const featureDetails = [
  {
    title: "Broadcaster",
    icon: "📡",
    desc: "A powerful tool for social media & digital marketing to share daily ads. Organize media files and WhatsApp contacts/groups to share multiple media files simultaneously without any hassle. Experience the power of marketing tools built especially for WhatsApp.",
    screenshot: "/toolkit-broadcaster.png",
    screenshotAlt: "Broadcaster — bulk messaging with scheduled broadcasts",
    label: "BROADCAST_MODULE",
    youtubeId: "gYPawJTsjv4"
  },
  {
    title: "Insta Downloader",
    icon: "📥",
    desc: "Download your Instagram photos, videos, stories, reels, and HD IGTV videos directly to your phone and instantly share them on WhatsApp. Also allows you to download posts from private accounts on Instagram.",
    screenshot: "/toolkit-insta-downloader.png",
    screenshotAlt: "Insta Downloader — download Instagram posts and stories",
    label: "INSTA_MODULE"
  },
  {
    title: "Memory Manager",
    icon: "💾",
    desc: "Manages the memory used by WhatsApp media files. Displays the real-time storage consumed by WhatsApp. Enables you to clean your WhatsApp media files at once if your phone runs out of memory.",
    screenshot: "/toolkit-memory-manager.png",
    screenshotAlt: "Memory Manager — real-time storage analytics and cleanup",
    label: "MEMORY_MODULE"
  },
  {
    title: "Sticker Maker",
    icon: "🎨",
    desc: "Create awesome stickers with a powerful sticker editor for WhatsApp by removing the background and adding texts, emojis, stickers, and so forth. Make your own sticker pack for WhatsApp.",
    screenshot: "/toolkit-sticker-maker.png",
    screenshotAlt: "Sticker Maker — create custom WhatsApp stickers",
    label: "STICKER_MODULE"
  },
  {
    title: "DP Editor",
    icon: "👤",
    desc: "Generate an attractive and fully customizable DP for WhatsApp using frames and square tools with minimal effort. Choose from dozens of styles including OLY, BLACK, DARK, and TINT presets.",
    screenshot: "/toolkit-dp-editor.png",
    screenshotAlt: "DP Editor — customizable profile picture frames",
    label: "DP_MODULE"
  },
  {
    title: "Video Trimmer",
    icon: "🎬",
    desc: "Trim your long videos into 30-second clips and share them in WhatsApp status. But not limited to, multiple video trim tools will help you to make your videos better.",
    screenshot: "/toolkit-video-trimmer.png",
    screenshotAlt: "Video Trimmer — trim videos for WhatsApp status",
    label: "VIDEO_MODULE"
  },
  {
    title: "Photo Editor",
    icon: "🖼️",
    desc: "Edit your photos like a pro for WhatsApp. Enhance your photos with filters and customize it with crop tools, stylish stickers, emojis, texts, and draw tools.",
    screenshot: "/toolkit-photo-editor.png",
    screenshotAlt: "Photo Editor — enhance photos with filters, stickers, and text",
    label: "PHOTO_MODULE"
  },
];

const highlights = [
  { label: "Platform", value: "Android" },
  { label: "Tools", value: "7+ Modules" },
  { label: "Focus", value: "WhatsApp" },
  { label: "Type", value: "Utility Suite" },
];

const techStack = ["Android", "Java", "Media Processing", "WhatsApp API", "Instagram API", "Storage Management", "Image Editing", "Video Processing"];

const keywords = "Toolkit for WhatsApp, WhatsApp tools, WhatsApp broadcaster, sticker maker, photo editor, video trimmer, Instagram downloader, Android app, Java mobile app, Sundeep Dayalan";

const additionalLD = [
  {
    "@context": "https://schema.org",
    "@type": "MobileApplication",
    "name": "Toolkit for WhatsApp",
    "description": "All-in-one WhatsApp toolkit Android app with 7+ modules: Broadcaster, Sticker Maker, Photo Editor, Video Trimmer, Instagram Downloader, DP Editor, and Memory Manager.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Android",
    "url": "https://www.sundeepdayalan.in/projects/toolkit-for-whatsapp",
    "creator": {
      "@type": "Person",
      "name": "Sundeep Dayalan",
      "url": "https://www.sundeepdayalan.in"
    },
    "dateCreated": "2020",
    "keywords": "WhatsApp toolkit, broadcaster, sticker maker, Android app"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sundeepdayalan.in/" },
      { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://www.sundeepdayalan.in/#projects" },
      { "@type": "ListItem", "position": 3, "name": "Toolkit for WhatsApp", "item": "https://www.sundeepdayalan.in/projects/toolkit-for-whatsapp" }
    ]
  }
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/project-whatsapp.png"
  keywords={keywords}
  additionalLD={additionalLD}
>
  <Navbar />

  <!-- HERO -->
  <section class="project-hero">
    <div class="project-hero-bg">
      <img src="/project-whatsapp.png" alt="Toolkit for WhatsApp — All-in-one Android app" width="1200" height="600" loading="eager" />
      <div class="project-hero-overlay"></div>
    </div>
    <div class="project-hero-content">
      <a href="/#projects" class="back-link">← RETURN TO BASE</a>
      <div class="project-hero-meta">
        <span class="project-badge android">ANDROID APP</span>
        <span class="project-badge utility">UTILITY SUITE</span>
      </div>
      <h1 class="project-hero-title">Toolkit for WhatsApp</h1>
      <p class="project-hero-tagline">All-powerful tools<br/><span class="tagline-accent">in one single app</span></p>
      <p class="project-hero-subtitle">Experience all-powerful tools for WhatsApp in one single app — from broadcasting and sticker creation to video editing and storage management.</p>
      <div class="project-hero-tags">
        {techStack.map(tag => <span class="hero-tag">{tag}</span>)}
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="section">
    <div class="container">
      <div class="highlights-grid">
        {highlights.map(h => (
          <div class="highlight-card">
            <span class="highlight-label">{h.label}</span>
            <span class="highlight-value">{h.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOP FEATURES OVERVIEW -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">SYSTEM MODULES</span>
        <h2 class="section-title">Top Features</h2>
        <div class="section-divider"></div>
      </div>
      <div class="top-features-grid">
        {topFeatures.map((feat, i) => (
          <a href={`#${featureDetails[i].label.toLowerCase()}`} class="top-feature-card animate-on-scroll" style={`animation-delay: ${i * 100}ms`}>
            <div class="top-feature-icon-wrap">
              <span class="top-feature-icon">{feat.icon}</span>
              <div class="icon-ring"></div>
            </div>
            <span class="top-feature-title">{feat.title}</span>
            <span class="top-feature-subtitle">{feat.subtitle}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY DOWNLOAD -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">ADVANTAGE ANALYSIS</span>
        <h2 class="section-title">Why Toolkit for WhatsApp?</h2>
        <div class="section-divider"></div>
      </div>
      <div class="project-terminal animate-on-scroll">
        <div class="terminal-header-mini">
          <span class="terminal-prompt">> cat app_manifest.txt</span>
          <span class="terminal-status">LOADING...</span>
        </div>
        <div class="project-text-block">
          <p>
            <span class="hl">Toolkit for WhatsApp</span> offers a comprehensive suite of powerful tools designed to enhance your WhatsApp experience. This all-in-one utility app brings together 7+ specialized modules covering everything from social media marketing to creative content creation.
          </p>
          <p>
            Each tool is designed to <span class="hl">simplify your tasks</span> and enhance your productivity on the platform. From social media marketing with the Broadcaster module to creative content creation with the Sticker Maker and Photo Editor — everything you need is in one app.
          </p>
          <p>
            The app prioritizes <span class="hl">user experience</span> with an intuitive interface, fast performance, and minimal storage footprint while delivering professional-grade functionality.
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILED FEATURES WITH SCREENSHOTS -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">MODULE DEEP-DIVE</span>
        <h2 class="section-title">Feature Details</h2>
        <div class="section-divider"></div>
      </div>
      <div class="feature-showcase-list">
        {featureDetails.map((feat, i) => (
          <div id={feat.label.toLowerCase()} class:list={['feature-showcase', 'animate-on-scroll', { 'reverse': i % 2 !== 0 }]}>
            <div class="feature-showcase-text">
              <div class="feature-showcase-header">
                <span class="feature-showcase-icon">{feat.icon}</span>
                <h3 class="feature-showcase-title">{feat.title}</h3>
              </div>
              <p class="feature-showcase-desc">{feat.desc}</p>
              {feat.youtubeId && (
                <a href={`https://www.youtube.com/watch?v=${feat.youtubeId}`} target="_blank" rel="noopener noreferrer" class="feat-yt-btn">
                  <span class="feat-yt-icon">▶</span>
                  <span>{feat.title} — How to use</span>
                </a>
              )}
              <span class="feature-showcase-label">{feat.label}</span>
            </div>
            {feat.screenshot ? (
              <div class="feature-showcase-phone">
                <div class="phone-frame">
                  <div class="frame-corner tl"></div>
                  <div class="frame-corner tr"></div>
                  <div class="frame-corner bl"></div>
                  <div class="frame-corner br"></div>
                  <div class="frame-scanline"></div>
                  <img src={feat.screenshot} alt={feat.screenshotAlt} loading="lazy" />
                  <div class="frame-hud">
                    <span class="frame-label">{feat.label}</span>
                    <span class="frame-status">● ACTIVE</span>
                  </div>
                </div>
              </div>
            ) : (
              <div class="feature-showcase-placeholder">
                <span class="placeholder-icon">{feat.icon}</span>
                <span class="placeholder-label">SCREENSHOT PENDING</span>
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BACK -->
  <div class="back-section">
    <a href="/#projects" class="back-link-bottom">← RETURN TO PROJECTS</a>
  </div>
</BaseLayout>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));

  });
</script>

<style is:global>
  /* ============================================
     PROJECT HERO
     ============================================ */
  .project-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .project-hero-bg {
    position: absolute;
    inset: 0;
  }

  .project-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.1) saturate(0.6);
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 14, 20, 0.3) 0%,
      rgba(10, 14, 20, 0.7) 50%,
      rgba(10, 14, 20, 0.95) 100%
    );
  }

  .project-hero-content {
    position: relative;
    z-index: 2;
    padding: var(--space-3xl) var(--space-2xl) var(--space-2xl);
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-primary-dim);
    text-decoration: none;
    letter-spacing: 0.1em;
    display: inline-block;
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-primary); }

  .project-hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin: var(--space-lg) 0 var(--space-md);
    flex-wrap: wrap;
  }

  .project-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    padding: 4px 12px;
    border: 1px solid;
    text-transform: uppercase;
  }

  .project-badge.android { color: var(--color-secondary); border-color: var(--color-secondary-dim); }
  .project-badge.utility { color: var(--color-primary); border-color: var(--color-primary-dim); }

  .project-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--color-text-bright);
    line-height: 1.1;
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .project-hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: var(--color-text-secondary);
    font-weight: 300;
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .tagline-accent {
    color: var(--color-primary);
    font-style: italic;
  }

  .project-hero-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
    max-width: 700px;
    line-height: 1.7;
  }

  .project-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-primary-dim);
    padding: 3px 10px;
    border: 1px solid var(--color-border);
    letter-spacing: 0.05em;
  }

  /* ============================================
     HIGHLIGHTS
     ============================================ */
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-md);
    padding: var(--space-xl) 0;
  }

  .highlight-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: border-color var(--transition-normal);
  }

  .highlight-card:hover { border-color: var(--color-border-bright); }

  .highlight-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-primary-dim);
    letter-spacing: 0.15em;
  }

  .highlight-value {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-bright);
  }

  /* ============================================
     TOP FEATURES OVERVIEW — SCI-FI CARDS
     ============================================ */
  .top-features-grid {
    display: grid;
    grid-template-columns: repeat(7, 1fr);
    gap: var(--space-md);
  }

  .top-feature-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: var(--space-xl) var(--space-sm);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    position: relative;
    cursor: pointer;
    text-decoration: none;
    transition: border-color var(--transition-normal), transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .top-feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary-dim), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .top-feature-card:hover {
    border-color: var(--color-primary-dim);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 229, 255, 0.08), inset 0 0 30px rgba(0, 229, 255, 0.02);
  }

  .top-feature-card:hover::before {
    opacity: 1;
  }

  .top-feature-icon-wrap {
    position: relative;
    width: 56px;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-xs);
  }

  .top-feature-icon {
    font-size: 1.8rem;
    position: relative;
    z-index: 1;
  }

  .icon-ring {
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .top-feature-card:hover .icon-ring {
    border-color: var(--color-primary-dim);
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.1);
  }

  .top-feature-title {
    font-family: var(--font-display);
    font-size: 0.78rem;
    font-weight: 600;
    color: var(--color-text-bright);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.3;
  }

  .top-feature-subtitle {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-text-dim);
    letter-spacing: 0.05em;
    text-transform: lowercase;
  }

  /* ============================================
     PROJECT TERMINAL
     ============================================ */
  .project-terminal {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .terminal-header-mini {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: rgba(0,229,255,0.03);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .terminal-prompt { color: var(--color-primary-dim); }
  .terminal-status { color: var(--color-secondary-dim); font-size: 0.65rem; letter-spacing: 0.15em; }

  .project-text-block {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
  }

  .hl { color: var(--color-primary); font-weight: 500; }

  /* ============================================
     FEATURE SHOWCASE — ALTERNATING LAYOUT
     ============================================ */
  .feature-showcase-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .feature-showcase {
    display: grid;
    grid-template-columns: 1fr 320px;
    gap: var(--space-2xl);
    align-items: center;
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: var(--space-2xl);
    transition: border-color var(--transition-normal);
  }

  .feature-showcase:hover {
    border-color: var(--color-border-bright);
  }

  .feature-showcase.reverse {
    grid-template-columns: 320px 1fr;
  }

  .feature-showcase.reverse .feature-showcase-text {
    order: 2;
  }

  .feature-showcase.reverse .feature-showcase-phone,
  .feature-showcase.reverse .feature-showcase-placeholder {
    order: 1;
  }

  .feature-showcase-header {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    margin-bottom: var(--space-md);
  }

  .feature-showcase-icon {
    font-size: 2.5rem;
  }

  .feature-showcase-title {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-text-bright);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .feature-showcase-desc {
    font-size: 0.95rem;
    color: var(--color-text-secondary);
    line-height: 1.8;
    margin-bottom: var(--space-lg);
  }

  .feature-showcase-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-primary-dim);
    letter-spacing: 0.2em;
    padding: 4px 12px;
    border: 1px solid var(--color-border);
    display: inline-block;
  }

  .feat-yt-btn {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.1em;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-primary-dim);
    transition: all var(--transition-normal);
    width: fit-content;
    margin-bottom: var(--space-md);
  }

  .feat-yt-btn:hover {
    background: rgba(0,229,255,0.08);
    border-color: var(--color-primary);
  }

  .feat-yt-icon {
    font-size: 0.7rem;
  }

  /* Phone screenshot frame with sci-fi HUD */
  .phone-frame {
    position: relative;
    overflow: hidden;
    background: var(--color-bg-panel);
    border: 1px solid var(--color-border);
    border-radius: 20px;
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .phone-frame:hover {
    border-color: var(--color-primary-dim);
    box-shadow: 0 0 30px rgba(0, 229, 255, 0.1), inset 0 0 40px rgba(0, 229, 255, 0.02);
  }

  .phone-frame img {
    width: 100%;
    height: auto;
    display: block;
    transition: transform var(--transition-normal), filter var(--transition-normal);
    filter: saturate(0.85) contrast(1.05);
  }

  .phone-frame:hover img {
    transform: scale(1.02);
    filter: saturate(1) contrast(1.1);
  }

  /* Corner brackets on phone frames */
  .phone-frame .frame-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    z-index: 3;
    transition: all var(--transition-normal);
  }

  .phone-frame .frame-corner.tl {
    top: 8px; left: 8px;
    border-top: 2px solid var(--color-primary-dim);
    border-left: 2px solid var(--color-primary-dim);
    border-top-left-radius: 4px;
  }

  .phone-frame .frame-corner.tr {
    top: 8px; right: 8px;
    border-top: 2px solid var(--color-primary-dim);
    border-right: 2px solid var(--color-primary-dim);
    border-top-right-radius: 4px;
  }

  .phone-frame .frame-corner.bl {
    bottom: 8px; left: 8px;
    border-bottom: 2px solid var(--color-primary-dim);
    border-left: 2px solid var(--color-primary-dim);
    border-bottom-left-radius: 4px;
  }

  .phone-frame .frame-corner.br {
    bottom: 8px; right: 8px;
