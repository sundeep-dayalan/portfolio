---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const title = "SkyBMS AI — Battery Management System | Sundeep Dayalan";
const description = "Comprehensive AI-powered battery management system with real-time cloud analytics, dynamic dashboards, chatbot integration, and lithium-ion safety monitoring.";

const highlights = [
  { label: "Focus", value: "Battery Safety" },
  { label: "Intelligence", value: "AI-Powered" },
  { label: "Data", value: "Real-Time Cloud" },
  { label: "Interface", value: "Dynamic Dashboard" },
  { label: "Interaction", value: "AI Chatbot" },
  { label: "Status", value: "Live Demo" },
];

const topFeatures = [
  { title: "Advanced", subtitle: "Analytics", icon: "📊" },
  { title: "AI", subtitle: "Integration", icon: "🤖" },
  { title: "Dynamic", subtitle: "User Dashboard", icon: "📈" },
  { title: "Realtime", subtitle: "Data Transmission", icon: "📡" },
  { title: "Cloud", subtitle: "Computation", icon: "☁️" },
];

const featureDetails = [
  {
    title: "Advanced Analytics",
    icon: "📊",
    desc: "Sky BMS leverages advanced algorithms to analyze data collected from the battery management system, such as temperature, voltage, charging status, capacity, and other critical factors. By using this data, Sky BMS can predict charge times based on battery temperature and usage patterns. In response to increasing voltage or temperature, Sky BMS can make necessary decisions, such as cutting off the circuit to prevent overheating and providing alerts on the user dashboard."
  },
  {
    title: "AI Integration",
    icon: "🤖",
    desc: "Sky BMS is enhanced with the power of AI, powered by OpenAI, to make predictive decisions such as stopping and resuming battery charging, cutting off the circuit, and more. Additionally, Sky BMS AI offers a feature that allows users to interact with the battery through natural language questions, providing a more intuitive experience than traditional fixed-response chatbots."
  },
  {
    title: "Dynamic User Dashboard",
    icon: "📈",
    desc: "Sky BMS offers a dynamic dashboard that provides users with real-time data on the state of charge (SoC), capacity, voltage, current, and alerts. It also delivers insights on usage patterns and voltage discharge levels. Additionally, the Sky BMS AI chatbot allows users to interact with the battery using natural language, enhancing the user experience beyond traditional interfaces."
  },
  {
    title: "Realtime Data Transmission",
    icon: "📡",
    desc: "All data collected from the battery and other sensors are transmitted to cloud servers. Sky BMS servers are hosted on AWS, providing a robust cloud environment for computations. Additionally, raw data is stored in a database for historical predictive analysis."
  },
  {
    title: "Cloud Computation",
    icon: "☁️",
    desc: "Sky BMS leverages cloud computation to enhance the performance and reliability of its battery management system. The data collected from various sensors is meticulously cleaned to ensure high output precision. Advanced algorithms then process this data to make critical decisions, such as controlling the sensors, managing charging cycles, and ensuring the safety and longevity of the battery."
  },
];

const hardwareImages = [
  { src: "/skybms-hw-1.png", alt: "Sky BMS hardware enclosure — front angle view with LCD display", label: "UNIT_FRONT_01" },
  { src: "/skybms-hw-2.png", alt: "Sky BMS hardware enclosure — rear angle view with power connector", label: "UNIT_REAR_02" },
  { src: "/skybms-hw-3.png", alt: "Sky BMS internal electronics — circuit boards, sensors, and wiring", label: "INTERNAL_03" },
  { src: "/skybms-hw-4.png", alt: "Sky BMS top view — SkyBMS logo displayed on OLED screen", label: "DISPLAY_04" },
  { src: "/skybms-hw-5.png", alt: "Sky BMS OLED display — BMS INFO: 26°C | 4.05V | 83.20%", label: "OLED_DATA_05" },
];

const techStack = ["Python", "Machine Learning", "Cloud Computing", "IoT", "Real-Time Analytics", "Chatbot AI", "REST APIs", "Dashboard UI", "AWS", "OpenAI"];

const keywords = "SkyBMS AI, battery management system, AI battery monitoring, lithium-ion battery safety, real-time cloud analytics, IoT battery, OpenAI chatbot, Sundeep Dayalan";

const additionalLD = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "SkyBMS AI — Battery Management System",
    "description": "AI-powered battery management system with real-time cloud analytics, dynamic dashboards, OpenAI chatbot integration, and lithium-ion battery safety monitoring.",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "Cloud, Web, IoT",
    "url": "https://www.sundeepdayalan.in/projects/sky-bms",
    "creator": {
      "@type": "Person",
      "name": "Sundeep Dayalan",
      "url": "https://www.sundeepdayalan.in"
    },
    "dateCreated": "2024",
    "keywords": "battery management, AI, IoT, real-time analytics, cloud computing, lithium-ion safety"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sundeepdayalan.in/" },
      { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://www.sundeepdayalan.in/#projects" },
      { "@type": "ListItem", "position": 3, "name": "SkyBMS AI — Battery Management System", "item": "https://www.sundeepdayalan.in/projects/sky-bms" }
    ]
  }
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/project-skybms.png"
  keywords={keywords}
  additionalLD={additionalLD}
>
  <Navbar />

  <!-- HERO -->
  <section class="project-hero">
    <div class="project-hero-bg">
      <img src="/project-skybms.png" alt="SkyBMS AI — Battery management system visualization" width="1200" height="600" loading="eager" />
      <div class="project-hero-overlay"></div>
    </div>
    <div class="project-hero-content">
      <a href="/#projects" class="back-link">← RETURN TO BASE</a>
      <div class="project-hero-meta">
        <span class="project-badge ai">AI-POWERED</span>
        <span class="project-badge live">LIVE DEMO AVAILABLE</span>
      </div>
      <h1 class="project-hero-title">SKY BMS</h1>
      <p class="project-hero-tagline">Power & Flexibility<br/><span class="tagline-accent">without the complexity</span></p>
      <p class="project-hero-subtitle">SkyBMS is engineered as a comprehensive, user-centric solution prioritizing safety and seamless functionality. With advanced algorithms, cutting-edge electronics, and AI integration, it delivers precise analytics without unnecessary complexity.</p>
      <div class="project-hero-tags">
        {techStack.map(tag => <span class="hero-tag">{tag}</span>)}
      </div>
      <div class="project-hero-actions">
        <a href="https://skybms.netlify.app/" target="_blank" rel="noopener noreferrer" class="hero-cta">
          <span class="cta-bracket">[</span> KNOW MORE <span class="cta-bracket">]</span>
        </a>
        <a href="https://skybms.netlify.app/" target="_blank" rel="noopener noreferrer" class="hero-cta secondary">
          <span class="cta-bracket">[</span> VIEW PORTFOLIO <span class="cta-bracket">]</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="section">
    <div class="container">
      <div class="highlights-grid">
        {highlights.map(h => (
          <div class="highlight-card">
            <span class="highlight-label">{h.label}</span>
            <span class="highlight-value">{h.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOP FEATURES OVERVIEW -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">SYSTEM CAPABILITIES</span>
        <h2 class="section-title">Top Features</h2>
        <div class="section-divider"></div>
      </div>
      <div class="top-features-grid">
        {topFeatures.map((feat, i) => (
          <div class="top-feature-card animate-on-scroll" style={`animation-delay: ${i * 100}ms`}>
            <div class="top-feature-icon-wrap">
              <span class="top-feature-icon">{feat.icon}</span>
              <div class="icon-ring"></div>
            </div>
            <span class="top-feature-title">{feat.title}</span>
            <span class="top-feature-subtitle">{feat.subtitle}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHY SKY BMS -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">ADVANTAGE ANALYSIS</span>
        <h2 class="section-title">Why Sky BMS?</h2>
        <div class="section-divider"></div>
      </div>
      <div class="project-terminal animate-on-scroll">
        <div class="terminal-header-mini">
          <span class="terminal-prompt">> cat skybms_why.txt</span>
          <span class="terminal-status">LOADING...</span>
        </div>
        <div class="project-text-block">
          <p>Sky BMS is a redesigned <span class="hl">battery management system</span> that addresses the current challenges faced by traditional battery management systems (BMS) for lithium-ion batteries. Traditional BMS often lack the computational capability needed to provide users with rich analytics and to make critical decisions.</p>
          <p>Sky BMS enhances these capabilities by enabling <span class="hl">real-time data transfer to the cloud</span>, where all received data is processed. This allows Sky BMS to provide users with updates and take necessary actions to preserve the lifespan and ensure the safety of lithium-ion batteries.</p>
          <p>Additionally, Sky BMS integrates <span class="hl">artificial intelligence</span>, which helps users obtain answers to natural queries and gain valuable insights.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DETAILED FEATURES -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">SYSTEM MODULES</span>
        <h2 class="section-title">Feature Details</h2>
        <div class="section-divider"></div>
      </div>
      <div class="feature-details-list">
        {featureDetails.map((feat, i) => (
          <div class="feature-detail-card animate-on-scroll">
            <div class="feature-detail-icon-wrapper">
              <span class="feature-detail-icon">{feat.icon}</span>
              <h3 class="feature-detail-title">{feat.title}</h3>
            </div>
            <div class="feature-detail-content">
              <p>{feat.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- HARDWARE GALLERY -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">HARDWARE PROTOTYPE</span>
        <h2 class="section-title">The Device</h2>
        <div class="section-divider"></div>
      </div>
      <div class="gallery-grid animate-on-scroll">
        {hardwareImages.map((img, i) => (
          <div class="gallery-frame">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <div class="frame-scanline"></div>
            <img src={img.src} alt={img.alt} loading="lazy" />
            <div class="frame-hud">
              <span class="frame-label">{img.label}</span>
              <span class="frame-status">● LIVE</span>
            </div>
            <div class="frame-caption-bar">
              <span class="frame-caption">{img.alt.split('—')[1]?.trim() || img.alt}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- VIDEO -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">DEMO FOOTAGE</span>
        <h2 class="section-title">Watch Sky BMS in Action</h2>
        <div class="section-divider"></div>
      </div>
      <div class="video-frame animate-on-scroll" id="video-container">
        <div class="frame-corner tl"></div>
        <div class="frame-corner tr"></div>
        <div class="frame-corner bl"></div>
        <div class="frame-corner br"></div>
        <div class="video-thumbnail" id="video-thumbnail">
          <img src="https://img.youtube.com/vi/-fJxf183J5U/maxresdefault.jpg" alt="Sky BMS Demo Video Thumbnail" loading="lazy" />
          <div class="video-overlay">
            <div class="play-button">
              <svg viewBox="0 0 68 48" width="68" height="48">
                <path d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55 C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19 C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="rgba(0, 229, 255, 0.85)"></path>
                <path d="M 45,24 27,14 27,34" fill="#0a0e14"></path>
              </svg>
            </div>
            <span class="play-label">▶ INITIALIZE PLAYBACK</span>
          </div>
          <div class="video-hud-top">
            <span class="vhud-label">FILE: SKYBMS_DEMO.mp4</span>
            <span class="vhud-status">READY</span>
          </div>
        </div>
        <div class="video-player" id="video-player" style="display:none;">
          <iframe 
            id="video-iframe"
            src="" 
            title="Sky BMS Demo Video" 
            frameborder="0" 
            allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" 
            allowfullscreen>
          </iframe>
        </div>
      </div>
    </div>
  </section>

  <!-- ACKNOWLEDGMENT -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">ACKNOWLEDGMENT</span>
        <h2 class="section-title">Credits & Disclaimer</h2>
        <div class="section-divider"></div>
      </div>
      <div class="project-terminal animate-on-scroll">
        <div class="terminal-header-mini">
          <span class="terminal-prompt">> cat acknowledgment.txt</span>
          <span class="terminal-status">VERIFIED</span>
        </div>
        <div class="project-text-block acknowledgment-block">
          <p>This system has been designed and developed as part of a school project for the <span class="hl">University of Colorado Denver</span> under the supervision of Professor <span class="hl">Dr. Liang He</span>. I extend my gratitude to Dr. He for his invaluable guidance.</p>
          <p class="disclaimer">This project is intended solely for <span class="hl">educational purposes</span> and is not intended for commercial use. I also express our thanks to the open-source libraries that have facilitated and simplified the development process.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- BACK -->
  <div class="back-section">
    <a href="/#projects" class="back-link-bottom">← RETURN TO PROJECTS</a>
  </div>
</BaseLayout>

<script>
  // Video thumbnail click handler
  document.addEventListener('DOMContentLoaded', () => {
    const thumbnail = document.getElementById('video-thumbnail');
    const player = document.getElementById('video-player');
    const iframe = document.getElementById('video-iframe');

    if (thumbnail && player && iframe) {
      thumbnail.addEventListener('click', () => {
        iframe.src = 'https://www.youtube.com/embed/-fJxf183J5U?autoplay=1';
        thumbnail.style.display = 'none';
        player.style.display = 'block';
      });
    }

    // Scroll animations
    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          entry.target.classList.add('is-visible');
        }
      });
    }, { threshold: 0.1 });

    document.querySelectorAll('.animate-on-scroll').forEach(el => observer.observe(el));
  });
</script>

<style>
  /* ============================================
     PROJECT HERO
     ============================================ */
  .project-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    overflow: hidden;
  }

  .project-hero-bg {
    position: absolute;
    inset: 0;
  }

  .project-hero-bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.1) saturate(0.6);
  }

  .project-hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(10, 14, 20, 0.3) 0%,
      rgba(10, 14, 20, 0.7) 50%,
      rgba(10, 14, 20, 0.95) 100%
    );
  }

  .project-hero-content {
    position: relative;
    z-index: 2;
    padding: var(--space-3xl) var(--space-2xl) var(--space-2xl);
    max-width: 1200px;
    margin: 0 auto;
    width: 100%;
  }

  .back-link {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--color-primary-dim);
    text-decoration: none;
    letter-spacing: 0.1em;
    display: inline-block;
    transition: color var(--transition-fast);
  }

  .back-link:hover { color: var(--color-primary); }

  .project-hero-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    margin: var(--space-lg) 0 var(--space-md);
    flex-wrap: wrap;
  }

  .project-badge {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    letter-spacing: 0.2em;
    padding: 4px 12px;
    border: 1px solid;
    text-transform: uppercase;
  }

  .project-badge.ai { color: var(--color-warning); border-color: rgba(255,182,39,0.4); }
  .project-badge.live { color: var(--color-primary); border-color: var(--color-primary-dim); }

  .project-hero-title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 6vw, 4rem);
    font-weight: 700;
    color: var(--color-text-bright);
    line-height: 1.1;
    margin-bottom: var(--space-sm);
    text-transform: uppercase;
  }

  .project-hero-tagline {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 3vw, 1.8rem);
    color: var(--color-text-secondary);
    font-weight: 300;
    margin-bottom: var(--space-md);
    line-height: 1.3;
  }

  .tagline-accent {
    color: var(--color-primary);
    font-style: italic;
  }

  .project-hero-subtitle {
    font-size: 0.95rem;
    color: var(--color-text-dim);
    margin-bottom: var(--space-lg);
    max-width: 700px;
    line-height: 1.7;
  }

  .project-hero-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
    margin-bottom: var(--space-lg);
  }

  .hero-tag {
    font-family: var(--font-mono);
    font-size: 0.65rem;
    color: var(--color-primary-dim);
    padding: 3px 10px;
    border: 1px solid var(--color-border);
    letter-spacing: 0.05em;
  }

  .project-hero-actions {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  .hero-cta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.15em;
    padding: var(--space-sm) var(--space-lg);
    border: 1px solid var(--color-primary-dim);
    transition: all var(--transition-normal);
  }

  .hero-cta:hover {
    background: rgba(0,229,255,0.08);
    border-color: var(--color-primary);
  }

  .hero-cta.secondary {
    color: var(--color-text-secondary);
    border-color: var(--color-border);
  }

  .hero-cta.secondary:hover {
    color: var(--color-primary);
    border-color: var(--color-primary);
    background: rgba(0,229,255,0.04);
  }

  .cta-bracket { color: var(--color-text-dim); }

  /* ============================================
     HIGHLIGHTS
     ============================================ */
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: var(--space-md);
    padding: var(--space-xl) 0;
  }

  .highlight-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
    transition: border-color var(--transition-normal);
  }

  .highlight-card:hover { border-color: var(--color-border-bright); }

  .highlight-label {
    font-family: var(--font-mono);
    font-size: 0.6rem;
    color: var(--color-primary-dim);
    letter-spacing: 0.15em;
  }

  .highlight-value {
    font-family: var(--font-display);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text-bright);
  }

  /* ============================================
     TOP FEATURES OVERVIEW — SCI-FI CARDS
     ============================================ */
  .top-features-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: var(--space-lg);
  }

  .top-feature-card {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    padding: var(--space-xl) var(--space-lg);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
    position: relative;
    transition: border-color var(--transition-normal), transform var(--transition-normal), box-shadow var(--transition-normal);
  }

  .top-feature-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, transparent, var(--color-primary-dim), transparent);
    opacity: 0;
    transition: opacity var(--transition-normal);
  }

  .top-feature-card:hover {
    border-color: var(--color-primary-dim);
    transform: translateY(-4px);
    box-shadow: 0 8px 32px rgba(0, 229, 255, 0.08), inset 0 0 30px rgba(0, 229, 255, 0.02);
  }

  .top-feature-card:hover::before {
    opacity: 1;
  }

  .top-feature-icon-wrap {
    position: relative;
    width: 64px;
    height: 64px;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-bottom: var(--space-sm);
  }

  .top-feature-icon {
    font-size: 2.2rem;
    position: relative;
    z-index: 1;
  }

  .icon-ring {
    position: absolute;
    inset: 0;
    border: 1px solid var(--color-border);
    border-radius: 50%;
    transition: border-color var(--transition-normal), box-shadow var(--transition-normal);
  }

  .top-feature-card:hover .icon-ring {
    border-color: var(--color-primary-dim);
    box-shadow: 0 0 15px rgba(0, 229, 255, 0.1);
  }

  .top-feature-title {
    font-family: var(--font-display);
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-bright);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    line-height: 1.3;
  }

  .top-feature-subtitle {
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-primary-dim);
    letter-spacing: 0.1em;
    text-transform: lowercase;
  }

  /* ============================================
     PROJECT TERMINAL
     ============================================ */
  .project-terminal {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    overflow: hidden;
  }

  .terminal-header-mini {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: var(--space-sm) var(--space-md);
    background: rgba(0,229,255,0.03);
    border-bottom: 1px solid var(--color-border);
    font-family: var(--font-mono);
    font-size: 0.75rem;
  }

  .terminal-prompt { color: var(--color-primary-dim); }
  .terminal-status { color: var(--color-secondary-dim); font-size: 0.65rem; letter-spacing: 0.15em; }

  .project-text-block {
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
