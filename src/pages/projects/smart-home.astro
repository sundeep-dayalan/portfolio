---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Navbar from '../../components/Navbar.astro';

const title = "Smart Home — IoT Home Automation | Sundeep Dayalan";
const description = "1st Runner Up at Smart India Hackathon 2018 — affordable IoT home automation and energy management system with voice control, retrofit integration, and real-time bill analytics.";

const highlights = [
  { label: "Rank", value: "1st Runner Up" },
  { label: "Event", value: "SIH 2018" },
  { label: "Venue", value: "NCL Pune" },
  { label: "Target", value: "Middle Class" },
  { label: "Control", value: "Voice Enabled" },
  { label: "Platform", value: "Android + IoT" },
];

const topFeatures = [
  { title: "Energy", subtitle: "Monitoring", icon: "⚡" },
  { title: "Retrofit", subtitle: "Integration", icon: "🔌" },
  { title: "Voice", subtitle: "Control", icon: "🗣️" },
  { title: "Mobile", subtitle: "Android App", icon: "📱" },
  { title: "Bill", subtitle: "Prediction", icon: "📊" },
];

const features = [
  {
    num: "01",
    title: "Energy Monitoring & Control",
    icon: "⚡",
    img: "/smart-home-screenshot-1.jpg",
    desc: "Real-time monitoring and control of energy usage across the entire building. Track consumption patterns per appliance, visualize daily usage data, and optimize electricity spend with intelligent automation rules."
  },
  {
    num: "02",
    title: "Existing Appliance Integration",
    icon: "🔌",
    img: "/smart-home-prototype.jpg",
    desc: "Works with your current appliances — no replacements required. Retrofit smart capabilities onto existing fans, lights, and gadgets through our custom relay modules. This is the key differentiator from mainstream smart home products in the market."
  },
  {
    num: "03",
    title: "Multi-Utility Controllers",
    icon: "🎛️",
    img: "/smart-home-prototype-implementation-1.jpg",
    desc: "Custom-built hardware controllers that manage multiple appliances from a single node. Reduces wiring complexity and hardware cost while maximizing coverage — designed to minimize BoM (Bill of Materials) without sacrificing capability."
  },
  {
    num: "04",
    title: "Voice Control Access",
    icon: "🗣️",
    img: "/smart-home-screenshot-2.PNG",
    desc: "Hands-free voice control designed for accessibility — enabling senior citizens and visually impaired users to interact effortlessly with home systems. No app required; just speak and the system responds."
  },
  {
    num: "05",
    title: "Android Companion App",
    icon: "📱",
    img: "/smart-home-screenshot-3.PNG",
    desc: "Full-featured Android application and a central tablet application for user convenience. Simple UI holding calculated values stored in the database — remote appliance control, energy consumption history, and scheduling from anywhere."
  },
  {
    num: "06",
    title: "Bill Prediction & Analytics",
    icon: "📊",
    img: "/smart-home-about-image.jpg",
    desc: "Predictive analytics engine that uses consumption patterns to forecast upcoming electricity bills. Empowers households with data-driven decisions before the bill arrives — a feature largely absent from other affordable home automation products."
  },
];

const screenshotImages = [
  { src: "/smart-home-screenshot-1.jpg", label: "APP_SCREEN_01", caption: "Smart Home Android app — appliance control and real-time energy dashboard" },
  { src: "/smart-home-screenshot-2.PNG", label: "APP_SCREEN_02", caption: "Voice control interface — hands-free appliance management" },
  { src: "/smart-home-screenshot-3.PNG", label: "APP_SCREEN_03", caption: "Energy analytics view — consumption history and bill prediction" },
];

const prototypeVideos = [
  {
    id: "proto-1",
    youtubeId: "NGprT9-FhNg",
    label: "PROTOTYPE_DEMO_01",
    title: "Prototype Demo — Part 1",
    desc: "Hardware prototype integrated with home appliances including lights and fans. Demonstrates real-time control via the Android app."
  },
  {
    id: "proto-2",
    youtubeId: "SvzY9U697Tg",
    label: "PROTOTYPE_DEMO_02",
    title: "Prototype Demo — Part 2",
    desc: "Full end-to-end demonstration of the prototype — multi-utility controller triggering multiple appliances simultaneously."
  },
];

const galleryImages = [
  { src: "/smart-home-winning-moment-photo-pune.jpeg",              label: "WIN_01", caption: "Winning moment — SIH 2018 at CSR, National Chemical Laboratory, Pune, India" },
  { src: "/smart-home-gallery-with-trophy.jpg",                    label: "WIN_02", caption: "1st Runner Up trophy — Smart India Hackathon 2018" },
  { src: "/smart-home-gallery-with-judge.jpg",                     label: "JUDGE_03", caption: "With the judge panel at Smart India Hackathon 2018" },
  { src: "/smart-home-gallery-team.jpg",                           label: "TEAM_04", caption: "Team photo — Smart Home at SIH 2018" },
  { src: "/smart-home-gallery-appreciation-from-ceo-yourstory.jpg",     label: "RECOG_05", caption: "Appreciation from CEO of YourStory.com" },
  { src: "/smart-home-gallery-appreciation-from-ceo-yourstory-2.JPG",   label: "RECOG_06", caption: "Appreciation from CEO of YourStory.com — with the team" },
  { src: "/smart-home-gallery-appreciation-from-college-chairman.jpg",  label: "RECOG_07", caption: "Appreciation from college Chairman, Principal and dignitaries" },
];

const techStack = ["Arduino", "IoT", "Android", "Java", "Firebase", "Voice Recognition", "Sensors", "Relay Modules", "ESP8266", "MQTT"];

const keywords = "smart home IoT automation, Arduino home automation, voice controlled home, energy monitoring, Firebase IoT, Android home control, Smart India Hackathon 2018, Sundeep Dayalan";

const additionalLD = [
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Smart Home — IoT Home Automation System",
    "description": "Affordable IoT home automation system with energy monitoring, voice control, retrofit integration, real-time bill analytics, and an Android companion app. 1st Runner Up at Smart India Hackathon 2018.",
    "applicationCategory": "HomeAndGardenApplication",
    "operatingSystem": "Android, IoT",
    "url": "https://www.sundeepdayalan.in/projects/smart-home",
    "creator": {
      "@type": "Person",
      "name": "Sundeep Dayalan",
      "url": "https://www.sundeepdayalan.in"
    },
    "award": "Smart India Hackathon 2018 — 1st Runner Up",
    "dateCreated": "2018",
    "keywords": "smart home, IoT automation, Arduino, voice control, energy monitoring, Android app"
  },
  {
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    "itemListElement": [
      { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://www.sundeepdayalan.in/" },
      { "@type": "ListItem", "position": 2, "name": "Projects", "item": "https://www.sundeepdayalan.in/#projects" },
      { "@type": "ListItem", "position": 3, "name": "Smart Home — IoT Home Automation", "item": "https://www.sundeepdayalan.in/projects/smart-home" }
    ]
  }
];
---

<BaseLayout
  title={title}
  description={description}
  ogImage="/project-smart-home.png"
  keywords={keywords}
  additionalLD={additionalLD}
>
  <Navbar />

  <!-- HERO -->
  <section class="project-hero">
    <div class="project-hero-bg">
      <img src="/project-smart-home.png" alt="Smart Home — IoT home automation system" width="1200" height="600" loading="eager" />
      <div class="project-hero-overlay"></div>
    </div>
    <div class="project-hero-content">
      <a href="/#projects" class="back-link">← RETURN TO BASE</a>
      <div class="project-hero-meta">
        <span class="project-badge runner">🥈 1ST RUNNER UP</span>
        <span class="project-badge iot">IOT PROJECT</span>
        <span class="project-badge proto">PROTOTYPE BUILT</span>
      </div>
      <h1 class="project-hero-title">Smart Home</h1>
      <p class="project-hero-tagline">Save electricity wisely.<br/><span class="tagline-accent">Smart living for everyone, not just smart cities.</span></p>
      <p class="project-hero-subtitle">An affordable IoT home automation and energy management system designed for the middle-class segment — retrofits existing appliances with voice control, real-time monitoring, and predictive bill analytics. Ranked #2 in India at Smart India Hackathon 2018.</p>
      <div class="project-hero-tags">
        {techStack.map(tag => <span class="hero-tag">{tag}</span>)}
      </div>
      <div class="project-hero-actions">
        <a href="https://www.youtube.com/watch?v=vnYoKdTUpxI" target="_blank" rel="noopener noreferrer" class="hero-cta">
          <span class="cta-bracket">[</span> WATCH REAL WORLD DEMO <span class="cta-bracket">]</span>
        </a>
        <a href="https://www.youtube.com/watch?v=NGprT9-FhNg" target="_blank" rel="noopener noreferrer" class="hero-cta secondary">
          <span class="cta-bracket">[</span> WATCH PROTOTYPE <span class="cta-bracket">]</span>
        </a>
      </div>
    </div>
  </section>

  <!-- HIGHLIGHTS -->
  <section class="section">
    <div class="container">
      <div class="highlights-grid">
        {highlights.map(h => (
          <div class="highlight-card">
            <span class="highlight-label">{h.label}</span>
            <span class="highlight-value">{h.value}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- TOP FEATURES -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">SYSTEM CAPABILITIES</span>
        <h2 class="section-title">What This System Does</h2>
        <div class="section-divider"></div>
      </div>
      <div class="top-features-grid animate-on-scroll">
        {topFeatures.map((feat, i) => (
          <div class="top-feature-card">
            <div class="top-feature-icon-wrap">
              <span class="top-feature-icon">{feat.icon}</span>
              <div class="icon-ring"></div>
            </div>
            <span class="top-feature-title">{feat.title}</span>
            <span class="top-feature-subtitle">{feat.subtitle}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">MISSION BRIEFING</span>
        <h2 class="section-title">About</h2>
        <div class="section-divider"></div>
      </div>
      <div class="about-layout animate-on-scroll">
        <div class="about-img-wrap">
          <div class="frame-corner tl"></div>
          <div class="frame-corner tr"></div>
          <div class="frame-corner bl"></div>
          <div class="frame-corner br"></div>
          <div class="frame-scanline"></div>
          <img src="/smart-home-about-image.jpg" alt="Smart Home prototype overview" loading="lazy" />
          <div class="frame-hud">
            <span class="frame-label">SYSTEM_OVERVIEW</span>
            <span class="frame-status">● LIVE</span>
          </div>
        </div>
        <div class="project-terminal about-terminal">
          <div class="terminal-header-mini">
            <span class="terminal-prompt">> cat smart_home_briefing.txt</span>
            <span class="terminal-status">DECRYPTING...</span>
          </div>
          <div class="project-text-block">
            <p>When it comes to energy saving, <span class="hl">energy management</span> is the process of monitoring, controlling, and conserving energy in a building. Today, many private companies sell smart home products — but they're priced for premium buyers only.</p>
            <p>Our approach is different. We target the <span class="hl">middle-class segment</span>, embodying the philosophy: <span class="hl">why only smart cities, and why not smart huts?</span> Our products integrate with <span class="hl">existing home appliances</span> — automating what you already own, not replacing it — a feature most competitors don't offer.</p>
            <p>We extend control through <span class="hl">multi-utility controllers</span> and <span class="hl">voice control</span> developed especially for senior citizens and the visually impaired. The system is designed by minimizing hardware cost to deliver affordable, efficient, market-ready products — with software that lets customers analyze <span class="hl">day-to-day energy consumption</span> and predict upcoming bills.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- CORE FEATURES -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">SYSTEM ARCHITECTURE</span>
        <h2 class="section-title">6 Features We Built</h2>
        <div class="section-divider"></div>
      </div>
      <div class="module-list">
        {features.map((feat) => (
          <div class="module-card animate-on-scroll">
            <div class="module-left">
              <span class="module-num">{feat.num}</span>
              <span class="module-icon">{feat.icon}</span>
              <h3 class="module-title">{feat.title}</h3>
              <p class="module-desc">{feat.desc}</p>
            </div>
            <div class="module-img-wrap">
              <div class="frame-corner tl"></div>
              <div class="frame-corner tr"></div>
              <div class="frame-corner bl"></div>
              <div class="frame-corner br"></div>
              <img src={feat.img} alt={feat.title} loading="lazy" />
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- SCREENSHOTS -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">APP INTERFACE</span>
        <h2 class="section-title">Screenshots</h2>
        <div class="section-divider"></div>
      </div>
      <p class="section-intro animate-on-scroll">Built for Android and a central tablet application. Simple UI with calculated values stored in the database — remote control, energy history, and bill prediction in one place.</p>
      <div class="screenshots-grid animate-on-scroll">
        {screenshotImages.map(img => (
          <div class="gallery-frame">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <div class="frame-scanline"></div>
            <div class="gallery-img-wrap">
              <img src={img.src} alt={img.caption} loading="lazy" />
            </div>
            <div class="frame-hud">
              <span class="frame-label">{img.label}</span>
              <span class="frame-status">● LIVE</span>
            </div>
            <div class="frame-caption-bar">
              <span class="frame-caption">{img.caption}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROTOTYPE IMPLEMENTATION -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">DEMO FOOTAGE</span>
        <h2 class="section-title">Prototype Implementation</h2>
        <div class="section-divider"></div>
      </div>
      <p class="section-intro animate-on-scroll">The developed product is integrated and tested in a home setup including lights, fans, and other appliances. Watch both prototype demonstrations below.</p>
      <div class="video-pair animate-on-scroll">
        {prototypeVideos.map(v => (
          <div class="video-block" id={`container-${v.id}`}>
            <div class="video-frame">
              <div class="frame-corner tl"></div>
              <div class="frame-corner tr"></div>
              <div class="frame-corner bl"></div>
              <div class="frame-corner br"></div>
              <div class="frame-scanline"></div>
              <div class="video-hud">
                <span class="frame-label">{v.label}</span>
                <span class="frame-status">● READY</span>
              </div>
              <div class="video-thumbnail" id={`thumb-${v.id}`}>
                <img src={`https://img.youtube.com/vi/${v.youtubeId}/maxresdefault.jpg`} alt={v.title} loading="lazy" />
                <div class="video-overlay">
                  <div class="play-button">
                    <svg viewBox="0 0 68 48" width="54" height="38">
                      <path d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="rgba(0,229,255,0.85)"></path>
                      <path d="M 45,24 27,14 27,34" fill="#0a0e14"></path>
                    </svg>
                  </div>
                  <span class="play-label">▶ INITIALIZE PLAYBACK</span>
                </div>
              </div>
              <div class="video-player" id={`player-${v.id}`} style="display:none;">
                <iframe
                  id={`iframe-${v.id}`}
                  src=""
                  title={v.title}
                  frameborder="0"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                  allowfullscreen>
                </iframe>
              </div>
            </div>
            <div class="video-meta">
              <h4 class="video-meta-title">{v.title}</h4>
              <p class="video-meta-desc">{v.desc}</p>
            </div>
          </div>
        ))}
      </div>

      <!-- Prototype photos -->
      <div class="proto-photos animate-on-scroll">
        <div class="gallery-frame">
          <div class="frame-corner tl"></div>
          <div class="frame-corner tr"></div>
          <div class="frame-corner bl"></div>
          <div class="frame-corner br"></div>
          <div class="gallery-img-wrap">
            <img src="/smart-home-prototype-implementation-1.jpg" alt="Prototype implementation — hardware setup 1" loading="lazy" />
          </div>
          <div class="frame-caption-bar">
            <span class="frame-caption">Prototype hardware setup — relay modules integrated with home appliances</span>
          </div>
        </div>
        <div class="gallery-frame">
          <div class="frame-corner tl"></div>
          <div class="frame-corner tr"></div>
          <div class="frame-corner bl"></div>
          <div class="frame-corner br"></div>
          <div class="gallery-img-wrap">
            <img src="/smart-home-prototype-implementation-2.jpg" alt="Prototype implementation — hardware setup 2" loading="lazy" />
          </div>
          <div class="frame-caption-bar">
            <span class="frame-caption">Multi-utility controller node — single board managing multiple appliances</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- REAL WORLD IMPLEMENTATION -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">FIELD DEPLOYMENT</span>
        <h2 class="section-title">Real World Implementation</h2>
        <div class="section-divider"></div>
      </div>
      <div class="realworld-layout animate-on-scroll">
        <div class="realworld-video">
          <div class="video-frame" id="container-realworld">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <div class="frame-scanline"></div>
            <div class="video-hud">
              <span class="frame-label">REALWORLD_DEMO_01</span>
              <span class="frame-status">● READY</span>
            </div>
            <div class="video-thumbnail" id="thumb-realworld">
              <img src="https://img.youtube.com/vi/vnYoKdTUpxI/maxresdefault.jpg" alt="Real world implementation demo" loading="lazy" />
              <div class="video-overlay">
                <div class="play-button">
                  <svg viewBox="0 0 68 48" width="54" height="38">
                    <path d="M66.52,7.74c-0.78-2.93-2.49-5.41-5.42-6.19C55.79,.13,34,0,34,0S12.21,.13,6.9,1.55C3.97,2.33,2.27,4.81,1.48,7.74C0.06,13.05,0,24,0,24s0.06,10.95,1.48,16.26c0.78,2.93,2.49,5.41,5.42,6.19C12.21,47.87,34,48,34,48s21.79-0.13,27.1-1.55c2.93-0.78,4.64-3.26,5.42-6.19C67.94,34.95,68,24,68,24S67.94,13.05,66.52,7.74z" fill="rgba(0,229,255,0.85)"></path>
                    <path d="M 45,24 27,14 27,34" fill="#0a0e14"></path>
                  </svg>
                </div>
                <span class="play-label">▶ INITIALIZE PLAYBACK</span>
              </div>
            </div>
            <div class="video-player" id="player-realworld" style="display:none;">
              <iframe
                id="iframe-realworld"
                src=""
                title="Real World Smart Home Implementation"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen>
              </iframe>
            </div>
          </div>
        </div>
        <div class="realworld-photos">
          <div class="gallery-frame">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <div class="gallery-img-wrap">
              <img src="/smart-home-realworld-implementation-1.JPG" alt="Real world home installation 1" loading="lazy" />
            </div>
            <div class="frame-caption-bar">
              <span class="frame-caption">Real world installation — smart relay fitted into existing switchboard</span>
            </div>
          </div>
          <div class="gallery-frame">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <div class="gallery-img-wrap">
              <img src="/smart-home-realworld-implementation-2.JPG" alt="Real world home installation 2" loading="lazy" />
            </div>
            <div class="frame-caption-bar">
              <span class="frame-caption">In-home deployment — existing appliances automated with zero hardware changes</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- AWARD -->
  <section class="section">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">MISSION ACCOMPLISHED</span>
        <h2 class="section-title">Award & Recognition</h2>
        <div class="section-divider"></div>
      </div>
      <div class="award-grid animate-on-scroll">
        <div class="award-card award-card--primary">
          <div class="award-photo-wrap">
            <div class="frame-corner tl"></div>
            <div class="frame-corner tr"></div>
            <div class="frame-corner bl"></div>
            <div class="frame-corner br"></div>
            <img src="/smart-home-winning-moment-photo-pune.jpeg" alt="Winning moment SIH 2018 at NCL Pune" loading="lazy" />
          </div>
          <div class="award-text">
            <div class="award-badge-row">
              <span class="award-badge">🥈 1ST RUNNER UP</span>
            </div>
            <h3 class="award-title">Smart India Hackathon 2018</h3>
            <p class="award-desc">Ranked #2 in India at the Smart India Hackathon 2018 Grand Finale held at CSR — National Chemical Laboratory (NCL), Pune, India. Smart India Hackathon is a nationwide platform by the Government of India to solve pressing societal problems through student innovation.</p>
          </div>
        </div>
        <div class="award-right">
          <div class="award-card award-card--sm">
            <div class="award-sm-icon">🏆</div>
            <div>
              <h4>Trophy & Certificate</h4>
              <p>Official 1st Runner Up trophy and certificate issued at the Grand Finale — recognizing the Smart Home system as one of India's top 2 affordable home automation solutions.</p>
            </div>
          </div>
          <div class="award-card award-card--sm">
            <div class="award-sm-icon">📰</div>
            <div>
              <h4>YourStory.com Recognition</h4>
              <p>Received personal appreciation from the CEO of YourStory.com — India's leading startup media platform — for the innovation and social impact of the project.</p>
              <a href="https://yourstory.com/2018/07/hope-over-heat-why-smart-cities-why-not-smart-huts-asks-a-young-student-in-bikaner#:~:text=It%20was%20at,the%20final%20winners." target="_blank" rel="noopener noreferrer" class="patent-link">Read the YourStory feature →</a>
            </div>
          </div>
          <div class="award-card award-card--sm">
            <div class="award-sm-icon">🏛️</div>
            <div>
              <h4>College Recognition</h4>
              <p>Formally appreciated by the College Chairman, Principal and academic dignitaries for representing the institution with distinction on a national stage.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="section">
    <div class="container">
