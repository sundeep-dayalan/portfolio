---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
---

<BaseLayout
  title="404 — Page Not Found | Sundeep Dayalan"
  description="The page you're looking for doesn't exist. Navigate back to Sundeep Dayalan's portfolio to explore projects, skills, and contact info."
  noindex={true}
>
  <Navbar />
  <main class="not-found-main">
    <div class="nf-frame">
      <div class="nf-corner tl"></div>
      <div class="nf-corner tr"></div>
      <div class="nf-corner bl"></div>
      <div class="nf-corner br"></div>

      <div class="nf-hud">
        <span class="nf-label">SYS::ERROR</span>
        <span class="nf-status">STATUS_404</span>
      </div>

      <div class="nf-code">404</div>
      <h1 class="nf-title">PAGE NOT FOUND</h1>
      <p class="nf-msg">
        The resource you requested has been relocated, declassified, or never existed.
      </p>

      <nav class="nf-nav" aria-label="Return navigation">
        <a href="/" class="nf-link">[ HOME ]</a>
        <a href="/#projects" class="nf-link">[ PROJECTS ]</a>
        <a href="/#about" class="nf-link">[ ABOUT ]</a>
        <a href="/#contact" class="nf-link">[ CONTACT ]</a>
      </nav>
    </div>
  </main>
</BaseLayout>

<style>
  .not-found-main {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    background: var(--color-bg-deep);
  }

  .nf-frame {
    position: relative;
    border: 1px solid var(--color-primary-dim);
    padding: 3rem 4rem;
    text-align: center;
    max-width: 600px;
    width: 100%;
    background: var(--color-bg-panel);
  }

  .nf-corner {
    position: absolute;
    width: 12px;
    height: 12px;
    border-color: var(--color-primary);
    border-style: solid;
  }
  .nf-corner.tl { top: -1px; left: -1px;  border-width: 2px 0 0 2px; }
  .nf-corner.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .nf-corner.bl { bottom: -1px; left: -1px;  border-width: 0 0 2px 2px; }
  .nf-corner.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

  .nf-hud {
    display: flex;
    justify-content: space-between;
    margin-bottom: 2rem;
    font-family: var(--font-mono);
    font-size: 0.7rem;
    color: var(--color-text-dim);
    letter-spacing: 0.1em;
  }

  .nf-code {
    font-family: var(--font-display);
    font-size: clamp(4rem, 15vw, 8rem);
    font-weight: 900;
    color: var(--color-primary);
    line-height: 1;
    text-shadow: 0 0 40px rgba(0, 229, 255, 0.4);
    letter-spacing: 0.1em;
    margin-bottom: 1rem;
  }

  .nf-title {
    font-family: var(--font-display);
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-text-bright);
    letter-spacing: 0.2em;
    margin-bottom: 1.5rem;
  }

  .nf-msg {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 2.5rem;
  }

  .nf-nav {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    justify-content: center;
  }

  .nf-link {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--color-primary);
    text-decoration: none;
    letter-spacing: 0.1em;
    transition: color var(--transition-fast), text-shadow var(--transition-fast);
  }

  .nf-link:hover,
  .nf-link:focus {
    color: var(--color-secondary);
    text-shadow: 0 0 8px rgba(0, 255, 157, 0.5);
    outline: 1px solid var(--color-secondary);
    outline-offset: 4px;
  }
</style>
