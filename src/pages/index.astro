  }
  .signal-bar:nth-child(1) { height: 4px; background: var(--color-secondary); }
  .signal-bar:nth-child(2) { height: 6px; background: var(--color-secondary); }
  .signal-bar:nth-child(3) { height: 8px; background: var(--color-secondary); }
  .signal-bar.active { height: 10px; background: var(--color-secondary); }

  .hero-content {
    display: grid;
    grid-template-columns: 380px 1fr;
    gap: var(--space-xl);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-top: none;
    padding: var(--space-xl);
    animation: fadeIn 1s ease 0.2s both;
  }

  /* Profile Image */
  .hero-profile-wrapper {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .profile-frame {
    position: relative;
    aspect-ratio: 1;
    overflow: hidden;
    border: 1px solid var(--color-border-bright);
  }

  .profile-corner {
    position: absolute;
    width: 16px;
    height: 16px;
    border-color: var(--color-primary);
    border-style: solid;
    z-index: 2;
  }
  .profile-corner.tl { top: -1px; left: -1px; border-width: 2px 0 0 2px; }
  .profile-corner.tr { top: -1px; right: -1px; border-width: 2px 2px 0 0; }
  .profile-corner.bl { bottom: -1px; left: -1px; border-width: 0 0 2px 2px; }
  .profile-corner.br { bottom: -1px; right: -1px; border-width: 0 2px 2px 0; }

  .profile-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: contrast(1.1) saturate(0.7);
    transition: filter var(--transition-slow);
    animation: digitalSliceGlitch 0.5s steps(1) both;
  }

  /* Data-stream slice glitch (pure pixel/slice blocks, zero shaking) */
  @keyframes digitalSliceGlitch {
    0%   { clip-path: inset(20% 0 80% 0); filter: contrast(4) hue-rotate(90deg) grayscale(1) brightness(2); }
    10%  { clip-path: inset(60% 0 10% 0); filter: contrast(3) hue-rotate(180deg) invert(1); }
    20%  { clip-path: inset(10% 0 50% 0); filter: sepia(1) hue-rotate(45deg) contrast(2); }
    30%  { clip-path: inset(80% 0 0% 0);  filter: saturate(3) hue-rotate(-90deg) brightness(0.5); }
    40%  { clip-path: inset(0% 0 0% 0);   filter: grayscale(1) brightness(3) contrast(3); }
    50%  { clip-path: inset(30% 0 30% 0); filter: hue-rotate(120deg) contrast(2); }
    60%  { clip-path: inset(0% 0 50% 0);  filter: saturate(4) brightness(0.5); }
    70%  { clip-path: inset(60% 0 5% 0);  filter: contrast(5); }
    80%  { clip-path: inset(0% 0 0% 0);   filter: grayscale(1) invert(0.2); }
    85%  { clip-path: inset(20% 0 20% 0); filter: saturate(3) contrast(2); }
    90%  { clip-path: inset(0% 0 10% 0);  filter: contrast(1.5) hue-rotate(45deg); }
    95%  { clip-path: inset(5% 0 5% 0);   filter: hue-rotate(15deg) contrast(1.2); }
    100% { clip-path: inset(0); filter: contrast(1.1) saturate(0.7); }
  }

  /* Glitch Box Overlay 1 (Cyan Data Blocks) */
  .profile-frame::before {
    content: '';
    position: absolute;
    background: rgba(0, 229, 255, 0.4);
    z-index: 4;
    pointer-events: none;
    mix-blend-mode: color-dodge;
    animation: glitchBlock1 0.5s steps(1) both;
  }

  /* Glitch Box Overlay 2 (Magenta Data Blocks) */
  .profile-frame::after {
    content: '';
    position: absolute;
    background: rgba(255, 0, 100, 0.4);
    z-index: 4;
    pointer-events: none;
    mix-blend-mode: overlay;
    animation: glitchBlock2 0.5s steps(1) both;
  }

  @keyframes glitchBlock1 {
    0%   { inset: 10% 20% 80% 10%; }
    15%  { inset: 50% 10% 10% 40%; }
    30%  { inset: 5% 60% 60% 5%; }
    45%  { inset: 80% 0 0 50%; opacity: 0; }
    60%  { inset: 0 0 0 0; background: rgba(0, 229, 255, 0.1); opacity: 1; }
    75%  { inset: 30% 30% 30% 30%; }
    90%  { inset: 10% 0 80% 10%; }
    100% { opacity: 0; inset: 0; }
  }

  @keyframes glitchBlock2 {
    0%   { inset: 20% 10% 50% 60%; }
    15%  { inset: 10% 50% 60% 10%; }
    30%  { inset: 60% 5% 5% 50%; }
    45%  { opacity: 0; }
    60%  { inset: 0 0 0 0; background: rgba(255, 0, 100, 0.1); opacity: 1; }
    75%  { inset: 40% 10% 20% 40%; }
    90%  { inset: 5% 60% 50% 5%; opacity: 0.5; }
    100% { opacity: 0; inset: 0; }
  }

  .profile-image:hover {
    filter: contrast(1.05) saturate(0.85);
  }

  .profile-scanline {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
