---

<BaseLayout
  title={title}
  description={description}
  ogImage="/og/home.png"
  keywords={keywords}
  additionalLD={additionalLD}
>
  <Navbar />
  <main id="main-content">

  <!-- ==================== HERO SECTION ==================== -->
  <section class="hero" id="hero">
    <div class="hero-container">
      <!-- Terminal header bar -->
      <div class="hero-terminal-bar">
        <div class="terminal-dots">
          <span class="dot dot-red"></span>
          <span class="dot dot-yellow"></span>
          <span class="dot dot-green"></span>
        </div>
        <span class="terminal-title">SUNDEEP_DAYALAN :: TERMINAL v4.2.1</span>
        <span class="terminal-signal">
          <div class="signal-bars">
            <span class="signal-bar"></span>
            <span class="signal-bar"></span>
            <span class="signal-bar"></span>
            <span class="signal-bar active"></span>
          </div>
          SIGNAL ACTIVE
        </span>
      </div>

      <div class="hero-content">
        <!-- Left: Profile image with CRT effect -->
        <div class="hero-profile-wrapper" id="profile-wrapper">
          <div class="profile-frame" id="profile-frame">
            <div class="profile-corner tl"></div>
            <div class="profile-corner tr"></div>
            <div class="profile-corner bl"></div>
            <div class="profile-corner br"></div>
            <Image
              src={assetImg('profile.png')}
              alt="Sundeep Dayalan - Senior Software Engineer"
              class="profile-image"
              width={400}
              height={400}
              loading="eager"
              fetchpriority="high"
            />
            <div class="profile-scanline"></div>
            <div class="profile-overlay"></div>
          </div>
          <div class="profile-data-strip">
            <span>ID: SD-2024</span>
            <span>STATUS: ACTIVE</span>
            <span>CLEARANCE: ████</span>
          </div>
        </div>

        <!-- Right: Hero text content -->
        <div class="hero-text">
          <div class="hero-subtitle-line">
            <span class="hero-role-label">SENIOR SOFTWARE ENGINEER</span>
            <span class="hero-coordinates">Y 04-DEC.97</span>
          </div>

          <h1 class="hero-title">
            <span class="hero-greeting">Hi, I'm</span>
            <span class="hero-name">Sundeep</span>
            <span class="hero-name-last">Dayalan</span>
          </h1>

          <p class="hero-tagline">
            Architecting high-throughput distributed systems, agentic AI infrastructure, and real-time fintech & Healthcare platforms at scale.
          </p>

          <div class="hero-meta">
            <span class="meta-item">
              <span class="meta-dot"></span>
              Columbus, Ohio
            </span>
            <span class="meta-item">
              <span class="meta-dot"></span>
              <a href="https://www.linkedin.com/in/sundeep-dayalan" target="_blank" rel="noopener noreferrer">LinkedIn</a>
            </span>
            <span class="meta-item">
              <span class="meta-dot"></span>
              <a href="https://github.com/sundeep-dayalan" target="_blank" rel="noopener noreferrer">GitHub</a>
            </span>
            <span class="meta-item">
              <span class="meta-dot"></span>
              MS Computer Science
            </span>
          </div>

          <div class="hero-links">
            <a href="mailto:sundeep.dayalan@gmail.com" class="hero-cta" id="hero-contact-btn">
              <span class="cta-bracket">[</span>
              INITIALIZE CONTACT
              <span class="cta-bracket">]</span>
            </a>
            <a href="mailto:sundeep.dayalan@gmail.com" class="hero-email">sundeep.dayalan@gmail.com</a>
          </div>

          <div class="hero-stats">
            <div class="stat">
              <span class="stat-value" data-value="5+">5+</span>
              <span class="stat-label">YRS EXP</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-value" data-value="5M+">5M+</span>
              <span class="stat-label">USERS SERVED</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-value" data-value="99.99%">99.99%</span>
              <span class="stat-label">UPTIME</span>
            </div>
            <div class="stat-divider"></div>
            <div class="stat">
              <span class="stat-value" data-value={`${projects.length}+`}>{projects.length}+</span>
              <span class="stat-label">PROJECTS</span>
            </div>
          </div>
        </div>
      </div>

      <!-- Bottom info strip -->
      <div class="hero-bottom-strip">
        <p class="strip-text">
          Senior software engineer architecting 5M+ user distributed systems across fintech, healthcare tech, and agentic AI. A published Springer researcher and pending patent holder , I bridge high-throughput engineering with production-grade LLM infrastructure, delivering 99.99% uptime and sub-200ms latency. From mentoring squads to authoring ADRs, I build the scalable systems and high-ownership cultures that drive modern engineering.
        </p>
      </div>
    </div>

    <!-- Ambient glow effects -->
    <div class="hero-glow hero-glow-1" aria-hidden="true"></div>
    <div class="hero-glow hero-glow-2" aria-hidden="true"></div>
  </section>

  <!-- ==================== ABOUT SECTION ==================== -->
  <section class="section" id="about">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">PERSONNEL FILE</span>
        <h2 class="section-title">About Me</h2>
        <div class="section-divider"></div>
      </div>

      <div class="about-content animate-on-scroll">
        <div class="about-terminal">
          <div class="terminal-header-mini">
            <span class="terminal-prompt">> cat about.txt</span>
            <span class="terminal-status">READING...</span>
          </div>
          <div class="about-text-block">
            <p>
            Senior software engineer with <span class="highlight">5+ years</span> architecting fault-tolerant, high-throughput distributed systems across <span class="highlight">Fintech, Healthcare Tech, and Agentic AI</span>.
            </p>
            <p>
            Expert in <span class="highlight">Python, Java, and React/TypeScript</span>, delivering production-grade LLM infrastructure and <span class="highlight">Kafka streaming pipelines serving 5M+ users</span> at sub-200ms p99 latency. Engineered RAG-powered analytics and RBAC-enforced financial APIs maintaining <span class="highlight">99.99% uptime</span>.
            </p>
            <p>
            Published <span class="highlight">Springer researcher</span> and pending patent holder in smart traffic systems. Proven force multiplier: mentors engineering squads, authors <span class="highlight">Architectural Decision Records (ADRs)</span>, and drives high-ownership cultures.
            </p>
          </div>
        </div>

        <div class="about-terminal">
          <div class="terminal-header-mini">
            <span class="terminal-prompt">> cat hobbies.txt</span>
            <span class="terminal-status">READING...</span>
          </div>
          <div class="about-text-block">
            <p>
              Besides my professional pursuits, I love to travel all around the globe. Meeting new people and communities, exploring new cultures, and tasting diverse foods are my hobbies.
            </p>
            <p>
              While I have traveled extensively, I am always looking forward to new adventures and would love for you to join me on my next trip.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ==================== SKILLS SECTION ==================== -->
  <section class="section" id="skills">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">TECH STACK MATRIX</span>
        <h2 class="section-title">Technical Skills</h2>
        <div class="section-divider"></div>
      </div>

      <div class="skills-grid">
        {skills.map((skill, index) => (
          <article class="skill-card animate-on-scroll" id={`skill-${index}`} style={`--delay: ${index * 80}ms`}>
            <div class="skill-card-header">
              <span class="skill-index">{String(index + 1).padStart(2, '0')}</span>
              <span class="skill-icon">{skill.icon}</span>
            </div>
            <h3 class="skill-name">{skill.name}</h3>
            <p class="skill-desc">{skill.desc}</p>
            <div class="skill-tags">
              {skill.tags.map(tag => (
                <span class="skill-tag">{tag}</span>
              ))}
            </div>
            <div class="skill-card-border"></div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== EXPERIENCE SECTION ==================== -->
  <section class="section" id="experience">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">MISSION LOG</span>
        <h2 class="section-title">Work Experience</h2>
        <div class="section-divider"></div>
      </div>

      <div class="experience-timeline">
        {experience.map((exp, index) => (
          <div class="exp-card animate-on-scroll" id={`exp-${index}`}>
            <div class="exp-card-header">
              <div class="exp-card-left">
                <h3 class="exp-role">{exp.role}</h3>
                <p class="exp-company">{exp.company}{exp.client ? ` (Client: ${exp.client})` : ''}</p>
              </div>
              <div class="exp-card-right">
                <span class="exp-period">{exp.period}</span>
                <span class="exp-location">
                  <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                  {exp.location}
                </span>
              </div>
            </div>
            <ul class="exp-bullets">
              {exp.bullets.map(bullet => (
                <li class="exp-bullet-item">
                  <span class="bullet-icon">▸</span>
                  <span>{bullet}</span>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== PROJECTS SECTION ==================== -->
  <section class="section" id="projects">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">OPERATIONS ARCHIVE</span>
        <h2 class="section-title">Key Projects</h2>
        <div class="section-divider"></div>
      </div>

      <div class="projects-grid">
        {projects.map((proj, index) => (
          proj.link ? (
            <a href={proj.link} class="project-card project-card-link animate-on-scroll" id={`proj-${index}`}>
              <div class="project-card-header">
                <h3 class="project-name">{proj.name}</h3>
                <span class="project-period">{proj.period}</span>
              </div>
              <p class="project-tech">{proj.tech}</p>
              <ul class="project-bullets">
                {proj.bullets.map(bullet => (
                  <li class="project-bullet-item">
                    <span class="bullet-icon">▸</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
              <span class="project-view-link">VIEW DETAILS →</span>
            </a>
          ) : (
            <div class="project-card animate-on-scroll" id={`proj-${index}`}>
              <div class="project-card-header">
                <h3 class="project-name">{proj.name}</h3>
                <span class="project-period">{proj.period}</span>
              </div>
              <p class="project-tech">{proj.tech}</p>
              <ul class="project-bullets">
                {proj.bullets.map(bullet => (
                  <li class="project-bullet-item">
                    <span class="bullet-icon">▸</span>
                    <span>{bullet}</span>
                  </li>
                ))}
              </ul>
            </div>
          )
        ))}
      </div>
    </div>
  </section>

  <!-- ==================== EDUCATION SECTION ==================== -->
  <section class="section" id="education">
    <div class="container">
      <div class="section-header animate-on-scroll">
        <span class="section-label">TRAINING RECORDS</span>
        <h2 class="section-title">Education</h2>
        <div class="section-divider"></div>
      </div>

      <div class="education-timeline">
        {education.map((edu, index) => (
          <div class="edu-card animate-on-scroll" id={`edu-${index}`}>
            <div class="edu-marker">
              <div class="marker-dot"></div>
              <div class="marker-line"></div>
            </div>
            {edu.link ? (
              <a href={edu.link} target="_blank" rel="noopener noreferrer" class="edu-content hover-lift" style="text-decoration: none; color: inherit; display: block;">
                <div class="edu-header">
                  <span class="edu-degree" style="text-decoration: underline; text-underline-offset: 4px; color: var(--color-primary);">{edu.degree}</span>
                  <span class="edu-year">{edu.year}</span>
                </div>
                <h3 class="edu-field">{edu.field}</h3>
                <p class="edu-school">{edu.school}</p>
                <div class="edu-meta">
                  <span class="edu-location">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {edu.location}
                  </span>
                  <span class="edu-gpa">{edu.gpa}</span>
                </div>
                {edu.thesis && <p class="edu-thesis"><span class="highlight">Thesis:</span> {edu.thesis}</p>}
              </a>
            ) : (
              <div class="edu-content">
                <div class="edu-header">
                  <span class="edu-degree">{edu.degree}</span>
                  <span class="edu-year">{edu.year}</span>
                </div>
                <h3 class="edu-field">{edu.field}</h3>
                <p class="edu-school">{edu.school}</p>
                <div class="edu-meta">
                  <span class="edu-location">
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
                    {edu.location}
                  </span>
                  <span class="edu-gpa">{edu.gpa}</span>
                </div>
                {edu.thesis && <p class="edu-thesis"><span class="highlight">Thesis:</span> {edu.thesis}</p>}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
