<script>
  // Sci-fi retro number scramble animation
  const GLITCH_CHARS = '0123456789ABCDEF▓▒░█';
  const DURATION = 1400; // ms total animation
  const FRAME_RATE = 50; // ms per frame

  function scrambleValue(el: HTMLElement) {
    const target = el.dataset.value || el.textContent || '';
    const frames = Math.floor(DURATION / FRAME_RATE);
    let frame = 0;

    el.classList.add('stat-scanning');

    const interval = setInterval(() => {
      frame++;
      const progress = frame / frames; // 0 → 1
      // How many chars are "locked in" (left to right)
      const locked = Math.floor(progress * target.length);

      let display = '';
      for (let i = 0; i < target.length; i++) {
        if (i < locked) {
          display += target[i];
        } else {
          const ch = target[i];
          // Keep non-alphanumeric chars (%, +, .) as-is for readability cues
          if (/[^a-zA-Z0-9]/.test(ch)) {
            display += ch;
          } else {
            display += GLITCH_CHARS[Math.floor(Math.random() * GLITCH_CHARS.length)];
          }
        }
      }
      el.textContent = display;

      if (frame >= frames) {
        clearInterval(interval);
        el.textContent = target;
        el.classList.remove('stat-scanning');
        el.classList.add('stat-done');
      }
    }, FRAME_RATE);
  }

  const statEls = document.querySelectorAll<HTMLElement>('.stat-value[data-value]');

  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        observer.unobserve(entry.target);
        setTimeout(() => scrambleValue(entry.target as HTMLElement), 120);
      }
    });
  }, { threshold: 0.5 });

  statEls.forEach(el => observer.observe(el));
</script>
