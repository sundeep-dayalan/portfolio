---
import BaseLayout from '../layouts/BaseLayout.astro';
import Navbar from '../components/Navbar.astro';
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const rawImages = import.meta.glob<{ default: ImageMetadata }>('/src/assets/images/**/*', { eager: true });
function assetImg(filename: string): ImageMetadata {
  const clean = filename.startsWith('/') ? filename.slice(1) : filename;
  const mod = rawImages[`/src/assets/images/${clean}`];
  if (!mod) throw new Error(`Image not found: ${clean}`);
  return mod.default;
}

