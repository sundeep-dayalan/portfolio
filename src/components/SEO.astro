---
interface Props {
  title: string;
  description: string;
  canonical?: string;
  image?: string;
  type?: string;
  publishedTime?: string;
  author?: string;
  keywords?: string;
  noindex?: boolean;
}

const {
  title,
  description,
  canonical = Astro.url.href,
  image = '/og-image.png',
  type = 'website',
  publishedTime,
  author = 'Sundeep Dayalan',
  keywords,
  noindex = false,
} = Astro.props;

const ogImageURL = new URL(image, Astro.site ?? Astro.url).href;
const robotsContent = noindex ? 'noindex, nofollow' : 'index, follow';
const googlebotContent = noindex
  ? 'noindex, nofollow'
  : 'index, follow, max-video-preview:-1, max-image-preview:large, max-snippet:-1';
---

<!-- Primary Meta Tags -->
<title>{title}</title>
<meta name="title" content={title} />
<meta name="description" content={description} />
<meta name="author" content={author} />
<meta name="robots" content={robotsContent} />
<meta name="googlebot" content={googlebotContent} />
{keywords && <meta name="keywords" content={keywords} />}

<!-- Canonical URL -->
<link rel="canonical" href={canonical} />

<!-- Open Graph / Facebook -->
<meta property="og:type" content={type} />
<meta property="og:url" content={canonical} />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:image" content={ogImageURL} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:site_name" content="Sundeep Dayalan" />
<meta property="og:locale" content="en_US" />
{publishedTime && <meta property="article:published_time" content={publishedTime} />}

<!-- Twitter Card -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:url" content={canonical} />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="twitter:image" content={ogImageURL} />
<meta name="twitter:creator" content="@sundeepdayalan" />

<!-- Favicon -->
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="icon" href="/favicon.ico" sizes="32x32" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />

<!-- Theme Color & App Meta -->
<meta name="theme-color" content="#0a0e14" />
<meta name="msapplication-TileColor" content="#0a0e14" />

<!-- Generator -->
<meta name="generator" content={Astro.generator} />

<!-- Preload critical self-hosted fonts (eliminates render-blocking FOUT) -->
<link rel="preload" href="/fonts/orbitron-latin.woff2" as="font" type="font/woff2" crossorigin />
<link rel="preload" href="/fonts/share-tech-mono-latin.woff2" as="font" type="font/woff2" crossorigin />

<!-- Google Search Console verification — replace content value after deploying -->
<meta name="google-site-verification" content="5zHy8hNtipLNJNEyU7BokJH91_O0hhGAGxBp-aY9DJE" />

